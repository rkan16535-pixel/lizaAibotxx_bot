import asyncio
from aiogram import Bot, Dispatcher, types
from aiogram.filters import Command
from dotenv import load_dotenv
import os

load_dotenv()

TOKEN = os.getenv("BOT_TOKEN")

bot = Bot(TOKEN)
dp = Dispatcher()


@dp.message(Command("start"))
async def start(message: types.Message):
    await message.answer(
        "🤖 Добро пожаловать в AI-конструктор!\n\n"
        "Команды:\n"
        "/ai — задать вопрос AI\n"
        "/help — помощь"
    )


@dp.message(Command("help"))
async def help_command(message: types.Message):
    await message.answer(
        "Доступные функции:\n"
        "✅ AI чат\n"
        "✅ Ответы на вопросы\n"
        "✅ Расширение модулями"
    )


@dp.message(Command("ai"))
async def ai_mode(message: types.Message):
    await message.answer(
        "Напиши свой вопрос после команды /ai"
    )


@dp.message()
async def chat(message: types.Message):
    text = message.text

    # пока простой ответ-заглушка
    # сюда подключим OpenAI
    await message.answer(
        f"Ты написал: {text}\n\n"
        "AI-модуль скоро подключим 🤖"
    )


async def main():
    await dp.start_polling(bot)


if __name__ == "__main__":
    asyncio.run(main())
